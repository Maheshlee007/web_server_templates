{
  "name": "fastify-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Fastify Backend with JWT Auth & RBAC - Supports MSSQL and PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "migrate": "node scripts/migrate.js",
    "migrate:up": "node scripts/migrate.js",
    "password:hash": "node scripts/password-helper.js hash",
    "password:verify": "node scripts/password-helper.js verify",
    "password:decrypt": "node scripts/decrypt.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^9.0.2",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.1.0",
    "mssql": "^11.0.1",
    "pg": "^8.13.1",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
