# ============================================================
# Fastify React App Backend - Environment Configuration Template
# Copy this file to .env and fill in your values
# Supports both MSSQL and PostgreSQL databases
# ============================================================

# Application
NODE_ENV=development
PORT=5000

# ============================================================
# DATABASE TYPE: Choose 'mssql' or 'postgres'
# ============================================================
DB_TYPE=postgres

# ============================================================
# SQL Server Configuration (required when DB_TYPE=mssql)
# ============================================================
MSSQL_SERVER=your-server.database.com
MSSQL_DATABASE=your_database
MSSQL_USER=your_user
MSSQL_PASSWORD=your_password
MSSQL_PORT=1433
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERTIFICATE=true

# ============================================================
# PostgreSQL Configuration (required when DB_TYPE=postgres)
# Docker: docker run -d --name postgres -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=4432
POSTGRES_DATABASE=mydb
POSTGRES_USER=lee
POSTGRES_PASSWORD=lee1234
POSTGRES_SSL=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-me-32-chars-min
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# API Configuration
API_PREFIX=/api

# Swagger Admin Secret — use Authorization: Bearer <secret> or ?secret= query param
SWAGGER_ADMIN_SECRET=change-me-admin-docs-secret

# Logging
LOG_LEVEL=info
