# ============================================================
# Fastify React App Backend - Environment Configuration Template
# Copy this file to .env and fill in your values
# ============================================================

# Application
NODE_ENV=development
PORT=5000

# SQL Server Configuration
MSSQL_SERVER=your-server.database.com
MSSQL_DATABASE=your_database
MSSQL_USER=your_user
MSSQL_PASSWORD=your_password
MSSQL_PORT=1433
MSSQL_ENCRYPT=true
MSSQL_TRUST_SERVER_CERTIFICATE=true

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# API Configuration
API_PREFIX=/api

# Swagger Admin Secret — append ?secret=<value> to /admin-docs to see admin API routes
SWAGGER_ADMIN_SECRET=change-me-admin-docs-secret

# Logging
LOG_LEVEL=info
